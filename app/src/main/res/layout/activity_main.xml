<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <!-- IP 设置区域 -->
    <LinearLayout
        android:id="@+id/ip_setting_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="打印机 IP:"
            android:textSize="16sp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/et_ip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="textUri"
            android:text="192.168.39.167"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_set_ip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="16sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- SNMP 查询按钮区域 -->
    <ScrollView
        android:id="@+id/snmp_buttons_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/ip_setting_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/snmp_buttons_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 第一行：状态查询 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btn_snmp_ready"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="就绪状态"
                    android:textSize="14sp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_idle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="空闲状态"
                    android:textSize="14sp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_print_total"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="打印总计数"
                    android:textSize="14sp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 第二行：状态查询 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btn_snmp_wake_state"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="唤醒状态设置"
                    android:textSize="14sp"
                    android:backgroundTint="#2196F3"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_current_job"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="当前作业 ID"
                    android:textSize="14sp"
                    android:backgroundTint="#9C27B0"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_cancel_job"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="取消作业"
                    android:textSize="14sp"
                    android:backgroundTint="#9C27B0"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 第三行：黄色耗材 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btn_snmp_yellow_full"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="黄色耗材满值"
                    android:textSize="14sp"
                    android:backgroundTint="#FFEB3B"
                    android:textColor="#000000"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_yellow_remain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="黄色耗材剩余"
                    android:textSize="14sp"
                    android:backgroundTint="#FFEB3B"
                    android:textColor="#000000"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_out_of_paper"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="缺纸状态"
                    android:textSize="14sp"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 第四行：红色和青色耗材 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btn_snmp_red_full"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="红色耗材满值"
                    android:textSize="14sp"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_red_remain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="红色耗材剩余"
                    android:textSize="14sp"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_cyan_full"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="青色耗材满值"
                    android:textSize="14sp"
                    android:backgroundTint="#03A9F4"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 第五行：青色和黑色耗材 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btn_snmp_cyan_remain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="青色耗材剩余"
                    android:textSize="14sp"
                    android:backgroundTint="#03A9F4"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_black_full"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="黑色耗材满值"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btn_snmp_black_remain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="黑色耗材剩余"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 结果展示区域 -->
    <EditText
        android:id="@+id/result_edittext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="200dp"
        android:padding="8dp"
        android:textSize="14sp"
        android:inputType="none"
        android:cursorVisible="false"
        android:background="@null"
        android:scrollbars="vertical"
        android:gravity="top|start"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/snmp_buttons_scroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 文件选择区域 -->
    <LinearLayout
        android:id="@+id/file_select_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/result_edittext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_select_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择 PDF 文件"
            android:textSize="16sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_selected_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未选择文件"
            android:textSize="14sp"
            android:textColor="#666666"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>

    <!-- 打印区域 -->
    <LinearLayout
        android:id="@+id/print_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/file_select_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_print_supported"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="打印机支持项"
            android:textSize="16sp"
            android:backgroundTint="#980000"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_print"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="打印文件"
            android:textSize="16sp"
            android:backgroundTint="#FF9800"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_print_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="打印结果："
            android:textSize="14sp"
            android:textColor="#666666" />
    </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>